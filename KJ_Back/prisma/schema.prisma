generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum PaymentMethod {
  CASH
  DEBIT_CARD
  CREDIT_CARD
  PIX
  OTHERS
}

enum Category {
  SALARY
  HOUSING
  TRANSPORT
  FOOD
  HEALTH_WELLNESS
  LEISURE_ENTERTAINMENT
  EDUCATION
  FINANCE_INVESTMENTS
  OTHERS
}

model Transaction {
  id                  String          @id @default(uuid())
  description         String
  amount              Decimal         @db.Decimal(10, 2)
  type                TransactionType
  category            Category        @default(OTHERS)
  paymentMethod       PaymentMethod   @default(OTHERS)
  date                DateTime
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  user                User            @relation(fields: [userId], references: [id])
  userId              String
  creditCard          CreditCard?     @relation(fields: [creditCardId], references: [id])
  creditCardId        String?
  parentTransaction   Transaction?    @relation("TransactionChildren", fields: [parentTransactionId], references: [id], onDelete: Cascade)
  parentTransactionId String?
  childTransactions   Transaction[]   @relation("TransactionChildren")
  isCardStatement     Boolean         @default(false)
  statementMonth      Int?
  statementYear       Int?

  @@map("transactions")
}

model CreditCard {
  id          String        @id @default(uuid())
  name        String
  limit       Decimal       @default(0) @db.Decimal(10, 2)
  closingDay  Int
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User          @relation(fields: [userId], references: [id])
  userId      String
  transactions Transaction[]

  @@map("credit_cards")
}

model User {
  id            String        @id @default(uuid())
  name          String
  email         String        @unique
  password_hash String
  createdAt     DateTime      @default(now())
  transactions  Transaction[]
  creditCards   CreditCard[]

  @@map("users")
}
