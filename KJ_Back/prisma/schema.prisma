generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum PaymentMethod {
  CASH
  DEBIT_CARD
  CREDIT_CARD
  PIX
  BANK_TRANSFER
  OTHERS
}

enum Category {
  SALARY
  HOUSING
  TRANSPORT
  FOOD
  HEALTH_WELLNESS
  LEISURE_ENTERTAINMENT
  EDUCATION
  FINANCE_INVESTMENTS
  OTHERS
}

enum TransactionSource {
  MANUAL
  PLUGGY
}

model Transaction {
  id                  String          @id @default(uuid())
  description         String
  amount              Decimal         @db.Decimal(10, 2)
  type                TransactionType
  category            Category        @default(OTHERS)
  paymentMethod       PaymentMethod   @default(OTHERS)
  date                DateTime
  source              TransactionSource @default(MANUAL)
  externalId          String?
  externalData        Json?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  user                User            @relation(fields: [userId], references: [id])
  userId              String
  pluggyAccount       PluggyAccount?  @relation(fields: [pluggyAccountId], references: [id])
  pluggyAccountId     String?
  creditCard          CreditCard?     @relation(fields: [creditCardId], references: [id])
  creditCardId        String?
  parentTransaction   Transaction?    @relation("TransactionChildren", fields: [parentTransactionId], references: [id], onDelete: Cascade)
  parentTransactionId String?
  childTransactions   Transaction[]   @relation("TransactionChildren")
  isCardStatement     Boolean         @default(false)
  statementMonth      Int?
  statementYear       Int?

  @@unique([source, externalId])
  @@map("transactions")
}

model CreditCard {
  id          String        @id @default(uuid())
  name        String
  limit       Decimal       @default(0) @db.Decimal(10, 2)
  closingDay  Int
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User          @relation(fields: [userId], references: [id])
  userId      String
  transactions Transaction[]

  @@map("credit_cards")
}

model User {
  id            String        @id @default(uuid())
  name          String
  email         String        @unique
  password_hash String
  createdAt     DateTime      @default(now())
  transactions  Transaction[]
  creditCards   CreditCard[]
  pluggyItems   PluggyItem[]
  pluggyAccounts PluggyAccount[]

  @@map("users")
}

model PluggyItem {
  id             String         @id @default(uuid())
  pluggyItemId   String         @unique
  status         String?
  connectorName  String?
  itemCreatedAt  DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  user           User           @relation(fields: [userId], references: [id])
  userId         String
  accounts       PluggyAccount[]

  @@unique([userId, pluggyItemId])
  @@map("pluggy_items")
}

model PluggyAccount {
  id                     String        @id @default(uuid())
  pluggyAccountId        String        @unique
  name                   String
  type                   String?
  subtype                String?
  currencyCode           String?
  balance                Decimal?      @db.Decimal(14, 2)
  lastSyncedAt           DateTime?
  lastSuccessfulSyncAt   DateTime?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt
  user                   User          @relation(fields: [userId], references: [id])
  userId                 String
  item                   PluggyItem    @relation(fields: [itemId], references: [id], onDelete: Cascade)
  itemId                 String
  transactions           Transaction[]

  @@unique([itemId, pluggyAccountId])
  @@map("pluggy_accounts")
}
